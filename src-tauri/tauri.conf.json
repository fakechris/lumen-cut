{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lumen-cut",
  "version": "0.2.1",
  "identifier": "com.fakechris.lumen-cut",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "lumen-cut",
        "width": 1100,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "resources": {
      "../sidecars/asr/main.py": "sidecars/asr/main.py",
      "../sidecars/diarize/main.py": "sidecars/diarize/main.py"
    }
  },
  "plugins": {}
}
